generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model StandardPostalCode {
  id          Int      @id @default(autoincrement())
  province    String
  city        String
  district    String
  postalCode  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserRouteImport {
  id            Int      @id @default(autoincrement())
  fileName      String
  importData    String
  resultData    String?
  status        String   @default("pending")
  errorMessage  String?
  createdAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
